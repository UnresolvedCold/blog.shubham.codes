---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
---

<Base>
  <section class="section pb-0">
    <div class="container">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-bold uppercase tracking-wide text-primary">
          Shubham's corner
        </p>
        <h1 class="mb-6 text-4xl font-bold leading-tight text-text-dark md:text-5xl">
          Notes on software, systems, AI/ML, DevOps, and optimization.
        </h1>
        <p class="text-lg leading-8 text-text">
          I use this space to share learnings, experiments, and technical
          decisions from backend engineering, cloud operations, and related
          problem-solving work.
        </p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <Posts posts={currentPosts} className="mb-16" />
      <Pagination currentPage={1} totalPages={totalPages} />
    </div>
  </section>
</Base>
